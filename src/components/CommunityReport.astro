---
---
<div class="w-full grid grid-cols-1 lg:grid-cols-12 gap-8" id="community-section">
  <!-- Left Side: Scam Report Submission Form -->
  <div class="w-full lg:col-span-5 bg-canvas border border-hairline rounded-lg p-6 shadow-level2 flex flex-col gap-4">
    <div class="flex flex-col gap-1 border-b border-hairline pb-4 select-none">
      <div class="flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-error animate-pulse"></span>
        <h3 class="text-sm font-semibold tracking-tight text-ink">Report a New Scam</h3>
      </div>
      <p class="text-xs text-mute leading-relaxed">
        Help protect the community. Flag suspicious numbers, websites, or email patterns. Reports are reviewed by our AI algorithms.
      </p>
    </div>

    <form id="scam-report-form" class="flex flex-col gap-4">
      <!-- Target URL/Entity -->
      <div class="flex flex-col gap-1.5">
        <label class="text-[10px] font-mono tracking-wider text-body uppercase" for="report-entity">Scam URL, Sender, or Phone Number</label>
        <input 
          type="text" 
          id="report-entity" 
          required
          placeholder="e.g., fedex-shipment-alert.xyz or +1 800-000-0000"
          autocomplete="off"
          spellcheck="false"
          autocorrect="off"
          autocapitalize="off"
          class="w-full h-10 border border-hairline rounded bg-canvas px-3 text-xs focus:border-ink focus:outline-none placeholder-mute transition-colors duration-150"
        />
      </div>

      <!-- Scam Category -->
      <div class="flex flex-col gap-1.5">
        <label class="text-[10px] font-mono tracking-wider text-body uppercase" for="report-category">Scam Category</label>
        <select 
          id="report-category"
          class="w-full h-10 border border-hairline rounded bg-canvas px-3 text-xs focus:border-hairline-strong focus:outline-none text-body"
        >
          <option value="Phishing Portal">🌐 Phishing Website Clone</option>
          <option value="eCommerce Fraud">🛒 eCommerce Shop Clone</option>
          <option value="Fake Job Offer">💼 Employment / Job Scam</option>
          <option value="Phishing Email">✉️ Spoofed / Phishing Email</option>
          <option value="SMS Text Scam">💬 Package Delivery / Bank SMS</option>
          <option value="Caller ID Spoof">📞 Telemarketing / Impersonation Call</option>
        </select>
      </div>

      <!-- Description details -->
      <div class="flex flex-col gap-1.5">
        <label class="text-[10px] font-mono tracking-wider text-body uppercase" for="report-details">Additional Details / Warning signs</label>
        <textarea 
          id="report-details" 
          rows="3"
          placeholder="e.g., Recruiter requested $50 for a background check via Telegram..."
          autocomplete="off"
          spellcheck="false"
          class="w-full border border-hairline rounded bg-canvas p-3 text-xs focus:border-ink focus:outline-none placeholder-mute font-sans resize-none transition-colors duration-150"
        ></textarea>
      </div>

      <button type="submit" class="h-10 w-full bg-primary hover:bg-primary/95 text-on-primary text-xs font-semibold rounded shadow-sm transition-colors cursor-pointer select-none">
        Submit Anonymously
      </button>
    </form>
  </div>

  <!-- Right Side: Scrolling List of Recent Scam Reports -->
  <div class="w-full lg:col-span-7 bg-canvas border border-hairline rounded-lg p-6 shadow-level2 flex flex-col gap-4">
    <div class="flex items-center justify-between border-b border-hairline pb-4 select-none">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-success"></span>
        <h3 class="text-sm font-semibold tracking-tight text-ink font-sans">Live Community Threat Feed</h3>
      </div>
      <span class="text-[9px] font-mono text-mute bg-canvas-soft-2 border border-hairline px-2 py-0.5 rounded">REALTIME LOGS</span>
    </div>

    <!-- Feed Container -->
    <div id="threat-feed" class="flex flex-col gap-4 max-h-[360px] overflow-y-auto pr-1">
      <!-- Populated via Javascript -->
    </div>
  </div>
</div>

<script>
  // Initial Mock database for threat feed
  const initialReports = [
    {
      entity: "usps-redelivery-postal.xyz",
      category: "SMS Text Scam",
      details: "Text message claiming package could not be delivered due to address mismatch. Asks for $1.50 fee to steal visa credentials.",
      time: "2 mins ago"
    },
    {
      entity: "+1 (888) 420-1209",
      category: "Caller ID Spoof",
      details: "Robocaller claiming they are from the IRS and demanding unpaid tax settlements. Threatens police dispatch.",
      time: "15 mins ago"
    },
    {
      entity: "trendy-shoes-sale.store",
      category: "eCommerce Fraud",
      details: "Pasted Facebook ad offering 90% off expensive sneakers. No physical address or valid contact info listed.",
      time: "1 hour ago"
    },
    {
      entity: "chase-update-verification.net",
      category: "Phishing Portal",
      details: "Lookalike login screen with Chase banking logo designed to harvest online account banking pins.",
      time: "3 hours ago"
    }
  ];

  function renderThreatFeed() {
    const feed = document.getElementById('threat-feed');
    if (!feed) return;

    // Retrieve customized local reports
    const customReports = JSON.parse(localStorage.getItem('trustchecker_user_reports') || '[]');
    const allReports = [...customReports, ...initialReports];

    feed.innerHTML = allReports.map(report => `
      <div class="flex flex-col gap-2 p-3 bg-canvas-soft-2 border border-hairline rounded select-none relative overflow-hidden group">
        <!-- Accent line based on category threat level -->
        <div class="absolute left-0 top-0 h-full w-[3px] bg-error/70"></div>
        <div class="flex items-center justify-between pl-1">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-semibold text-ink font-mono">${report.entity}</span>
            <span class="text-[9px] font-mono bg-error/10 text-error px-1.5 py-0.5 rounded font-semibold tracking-wider uppercase border border-error/10">${report.category}</span>
          </div>
          <span class="text-[9px] text-mute font-mono">${report.time}</span>
        </div>
        <p class="text-xs text-body leading-relaxed pl-1">
          ${report.details}
        </p>
      </div>
    `).join('');
  }

  function init() {
    renderThreatFeed();

    // Form submission
    const form = document.getElementById('scam-report-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const entityEl = document.getElementById('report-entity') as HTMLInputElement;
        const categoryEl = document.getElementById('report-category') as HTMLSelectElement;
        const detailsEl = document.getElementById('report-details') as HTMLTextAreaElement;

        if (!entityEl || !categoryEl || !detailsEl) return;

        const newReport = {
          entity: entityEl.value.trim(),
          category: categoryEl.value,
          details: detailsEl.value.trim() || "Suspicious scam behavior reported by user.",
          time: "Just now"
        };

        // Add to local reports
        const customReports = JSON.parse(localStorage.getItem('trustchecker_user_reports') || '[]');
        customReports.unshift(newReport);
        localStorage.setItem('trustchecker_user_reports', JSON.stringify(customReports));

        // Reset form
        form.reset();

        // Re-render feed with feedback
        renderThreatFeed();
        alert('Thank you! Your scam report has been logged and queued for AI analysis.');
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
