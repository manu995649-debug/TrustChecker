---
import Layout from '../layouts/Layout.astro';
import InteractiveChecker from '../components/InteractiveChecker.astro';
import HistoryLog from '../components/HistoryLog.astro';
import CommunityReport from '../components/CommunityReport.astro';

// We'll prepare a default mock report for the visual demo card
const mockReport = {
  domain: 'dhl-delivery-support.xyz',
  score: 14,
  explanation: 'Warning: High risk of fraud detected on dhl-delivery-support.xyz. This domain displays patterns of brand impersonation (spoofing DHL logistics) and phishing. It was registered only 4 days ago under a low-reputation top-level domain (.xyz). Do not input credit card details or address information.'
};
---

<Layout activePath="/">
  <!-- Hero Section -->
  <section class="relative pt-12 pb-16 md:py-24 text-center max-w-4xl mx-auto flex flex-col items-center gap-6 select-none">
    <!-- Announcement Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-hairline bg-canvas text-xs text-body hover:bg-canvas-soft transition-colors shadow-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
      <span class="font-mono text-[10px] tracking-wider uppercase font-semibold">Introducing TrustChecker AI v4</span>
    </div>

    <!-- Main Headline -->
    <h1 class="display-xl text-ink font-semibold max-w-3xl leading-tight">
      Is it legit or a scam.
    </h1>

    <!-- Subheadline -->
    <p class="text-base md:text-lg text-body max-w-xl leading-relaxed">
      Verify suspicious URLs, emails, SMS alerts, job offers, eCommerce shops, and phone numbers instantly with deep AI fraud heuristics.
    </p>

    <!-- Quick Direct Input Box in Hero -->
    <div class="w-full max-w-2xl bg-canvas border border-hairline rounded-lg p-2 shadow-level3 flex flex-col sm:flex-row gap-2 mt-4 focus-within:border-ink transition-all duration-200">
      <div class="flex-grow flex items-center px-3 gap-2">
        <svg class="w-5 h-5 text-mute flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input 
          type="text" 
          id="hero-search-input"
          placeholder="Paste URL, text message, phone number, or job offer..."
          autocomplete="off"
          spellcheck="false"
          autocorrect="off"
          autocapitalize="off"
          class="w-full h-10 text-sm focus:outline-none text-ink bg-transparent"
        />
      </div>
      <button id="hero-search-btn" class="h-11 sm:h-10 px-6 bg-primary text-on-primary text-xs font-semibold rounded-md hover:bg-primary/95 transition-all select-none shadow-sm cursor-pointer whitespace-nowrap">
        Scan Instantly
      </button>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-mute font-mono mt-2">
      <div class="flex items-center gap-1.5">
        <span class="text-success">✔</span> 100% Confidential
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-success">✔</span> Encrypted Queries
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-success">✔</span> Zero Data Logs Saved
      </div>
    </div>
  </section>

  <!-- Monochrome Brands Logostrip -->
  <section class="w-full border-y border-hairline py-8 mb-16 select-none bg-canvas/30 backdrop-blur-sm relative z-10">
    <div class="max-w-6xl mx-auto flex flex-col items-center gap-4">
      <span class="caption-mono text-[10px] text-mute tracking-widest font-semibold">PROTECTING USERS FROM BRAND IMPERSONATION</span>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 opacity-40 grayscale hover:opacity-50 transition-opacity">
        <!-- Mock Logos -->
        <span class="text-sm font-semibold tracking-tight font-sans">amazon</span>
        <span class="text-sm font-semibold tracking-tight font-sans font-serif">PayPal</span>
        <span class="text-sm font-semibold tracking-tight font-sans italic font-bold text-sky-700">USPS</span>
        <span class="text-sm font-semibold tracking-tight font-sans font-mono tracking-wider">CHASE</span>
        <span class="text-sm font-semibold tracking-tight font-sans">FedEx</span>
        <span class="text-sm font-semibold tracking-tight font-sans font-semibold text-red-600">NETFLIX</span>
      </div>
    </div>
  </section>

  <!-- Interactive Console Segment -->
  <section id="analyze-section" class="w-full mb-16 scroll-mt-20">
    <div class="max-w-4xl mx-auto flex flex-col gap-4">
      <div class="flex flex-col gap-1.5 text-center mb-4 select-none">
        <span class="caption-mono text-link font-semibold">SCANNER CONSOLE</span>
        <h2 class="display-lg text-ink font-semibold">Analyze suspicious content.</h2>
        <p class="text-sm text-body max-w-md mx-auto">Select the appropriate checker tool below and input your content to view a forensic security report.</p>
      </div>

      <!-- Checker Tabs -->
      <InteractiveChecker />
    </div>
  </section>

  <!-- Two Column Layout: History + How it works -->
  <section class="w-full grid grid-cols-1 md:grid-cols-12 gap-8 mb-16 relative z-10">
    <!-- Left: History log -->
    <div class="md:col-span-5 flex flex-col">
      <HistoryLog />
    </div>

    <!-- Right: How TrustChecker Works (Timeline style) -->
    <div class="md:col-span-7 bg-canvas border border-hairline rounded-lg p-6 shadow-level2 flex flex-col gap-6 select-none">
      <div class="flex items-center gap-2 border-b border-hairline pb-4">
        <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-sm font-semibold tracking-tight text-ink">How TrustChecker Protects You</h3>
      </div>

      <div class="flex flex-col gap-6">
        <!-- Step 1 -->
        <div class="flex items-start gap-4">
          <div class="w-6 h-6 rounded-full bg-canvas-soft-2 border border-hairline flex items-center justify-center text-xs font-mono font-semibold text-ink flex-shrink-0">
            01
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs font-semibold text-ink">Submit Suspicious Text or Link</span>
            <span class="text-xs text-body leading-relaxed">Copy and paste any suspicious email, text message, job description, or URL into our tabbed dashboard console.</span>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex items-start gap-4">
          <div class="w-6 h-6 rounded-full bg-canvas-soft-2 border border-hairline flex items-center justify-center text-xs font-mono font-semibold text-ink flex-shrink-0">
            02
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs font-semibold text-ink">Forensic Cyber Heuristic Audit</span>
            <span class="text-xs text-body leading-relaxed">Our AI parser evaluates SSL encryption validity, domain registration age, brand spoofing syntax, and phishing keywords.</span>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex items-start gap-4">
          <div class="w-6 h-6 rounded-full bg-canvas-soft-2 border border-hairline flex items-center justify-center text-xs font-mono font-semibold text-ink flex-shrink-0">
            03
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs font-semibold text-ink">Get Clear Trust Scores & Explanations</span>
            <span class="text-xs text-body leading-relaxed">Receive a detailed trust score between 0 and 100, lists of specific Red Flags/Green Flags, and plain-English safety recommendations.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Demo Preview Report Card Segment -->
  <section class="w-full mb-16 select-none bg-canvas-soft-2/60 border border-hairline rounded-lg p-6 md:p-8 shadow-level1 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-64 h-64 bg-error/5 blur-3xl pointer-events-none rounded-full"></div>
    
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 border-b border-hairline pb-6 mb-6">
      <div class="flex flex-col gap-1">
        <span class="caption-mono text-error font-semibold">PREVIEW SAMPLE REPORT</span>
        <h3 class="text-lg font-semibold tracking-tight text-ink">Example of a high-risk phishing report.</h3>
        <p class="text-xs text-body">This is a live representation of how TrustChecker visualizes detected scam indicators for a suspicious delivery tracking link.</p>
      </div>
      <a href="#analyze-form" class="h-9 px-4 inline-flex items-center justify-center text-xs font-semibold rounded bg-primary text-on-primary hover:bg-primary/90 transition-all shadow-sm">
        Run Your Own Scan
      </a>
    </div>

    <!-- Static Preview of AnalysisCard -->
    <div class="w-full bg-canvas border border-hairline rounded-lg p-6 shadow-level3 flex flex-col lg:flex-row gap-6 relative">
      <!-- Left side: SVG Dial Mockup -->
      <div class="w-full lg:w-4/12 flex flex-col items-center border-b lg:border-b-0 lg:border-r border-hairline pb-6 lg:pb-0 lg:pr-6 gap-4">
        <span class="text-[9px] font-mono tracking-wider text-mute">RISK ASSESSMENT DIAL</span>
        
        <!-- Score dial SVG static -->
        <div class="relative w-36 h-36 flex items-center justify-center">
          <div class="absolute inset-0 rounded-full blur-lg opacity-20 bg-error/5"></div>
          <svg class="w-full h-full -rotate-90" viewBox="0 0 160 160">
            <circle cx="80" cy="80" r="70" fill="transparent" stroke="var(--color-hairline)" stroke-width="10"/>
            <!-- 14 / 100 circumference -->
            <circle cx="80" cy="80" r="70" fill="transparent" stroke="var(--color-error)" stroke-width="10" stroke-linecap="round" stroke-dasharray="439.8" stroke-dashoffset="378.2"/>
          </svg>
          <div class="absolute flex flex-col items-center justify-center text-center">
            <span class="text-3xl font-semibold text-error font-sans">14</span>
            <span class="text-[8px] font-mono text-mute mt-0.5">SCORE</span>
          </div>
        </div>
        <div class="px-2.5 py-0.5 rounded-full text-[9px] font-mono font-semibold tracking-widest text-error bg-error/5 border border-error/20">
          DANGEROUS
        </div>
      </div>

      <!-- Right side details -->
      <div class="w-full lg:w-8/12 flex flex-col gap-4">
        <div>
          <h4 class="text-sm font-semibold text-ink">{mockReport.domain}</h4>
          <span class="text-[10px] text-mute font-mono">Registered 4 days ago &bull; Verified Phishing Clone</span>
        </div>
        
        <p class="text-xs text-body leading-relaxed bg-canvas-soft-2 border border-hairline p-3 rounded">
          {mockReport.explanation}
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-[11px]">
          <div>
            <span class="text-error font-semibold font-mono block mb-1.5">⚠ RED FLAGS (2)</span>
            <ul class="flex flex-col gap-1 text-body">
              <li>&bull; Brand Impersonation (DHL Spoof)</li>
              <li>&bull; Registered only 4 days ago</li>
            </ul>
          </div>
          <div>
            <span class="text-success font-semibold font-mono block mb-1.5">✔ GREEN FLAGS (1)</span>
            <ul class="flex flex-col gap-1 text-body">
              <li>&bull; Valid SSL/HTTPS certificate</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Community Reports Feed segment -->
  <section class="w-full mb-16 scroll-mt-20" id="reports-feed-section">
    <div class="max-w-6xl mx-auto flex flex-col gap-6">
      <div class="flex flex-col gap-1.5 select-none text-center lg:text-left">
        <span class="caption-mono text-error font-semibold">COMMUNITY FEED</span>
        <h2 class="display-lg text-ink font-semibold">Live Threat Database.</h2>
        <p class="text-sm text-body">Browse ongoing scams reported by other users, or submit a suspicious link/number anonymously to warn others.</p>
      </div>

      <CommunityReport />
    </div>
  </section>

  <!-- Platform FAQ accordion -->
  <section class="w-full mb-8 max-w-3xl mx-auto select-none">
    <div class="border-b border-hairline pb-4 mb-6 text-center">
      <span class="caption-mono text-mute font-semibold">FAQ</span>
      <h2 class="display-lg text-ink font-semibold mt-1">Frequently Asked Questions.</h2>
    </div>

    <div class="flex flex-col border border-hairline rounded-lg bg-canvas overflow-hidden">
      <!-- FAQ 1 -->
      <div class="faq-item border-b border-hairline">
        <button class="faq-btn w-full px-5 py-4 flex items-center justify-between hover:bg-canvas-soft transition-colors text-left focus:outline-none">
          <span class="text-xs font-semibold text-ink">Is TrustChecker really free and private?</span>
          <svg class="w-4 h-4 text-mute transition-transform faq-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="faq-panel max-h-0 overflow-hidden transition-all duration-300">
          <p class="px-5 pb-4 text-xs text-body leading-relaxed bg-canvas-soft/30">
            Yes. TrustChecker is 100% free for individual consumers. To preserve your privacy, we operate on a strict zero-knowledge security policy. Your searches are processed client-side and compared with local databases; we do not store, catalog, or share the contents of your text scans, job offers, or URLs.
          </p>
        </div>
      </div>

      <!-- FAQ 2 -->
      <div class="faq-item border-b border-hairline">
        <button class="faq-btn w-full px-5 py-4 flex items-center justify-between hover:bg-canvas-soft transition-colors text-left focus:outline-none">
          <span class="text-xs font-semibold text-ink">How accurate is the AI Trust Score?</span>
          <svg class="w-4 h-4 text-mute transition-transform faq-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="faq-panel max-h-0 overflow-hidden transition-all duration-300">
          <p class="px-5 pb-4 text-xs text-body leading-relaxed bg-canvas-soft/30">
            Our AI Trust Score uses advanced structural heuristics, registrar age checks, typo-squatting algorithms, and natural language processing (NLP) search weights. It analyzes patterns that scammers commonly use (such as cheap TLDs, messaging redirections, public email hosts, and financial bait phrasing) to calculate risk with over 94% threat detection accuracy.
          </p>
        </div>
      </div>

      <!-- FAQ 3 -->
      <div class="faq-item">
        <button class="faq-btn w-full px-5 py-4 flex items-center justify-between hover:bg-canvas-soft transition-colors text-left focus:outline-none">
          <span class="text-xs font-semibold text-ink">What should I do if a URL has a low Trust Score?</span>
          <svg class="w-4 h-4 text-mute transition-transform faq-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="faq-panel max-h-0 overflow-hidden transition-all duration-300">
          <p class="px-5 pb-4 text-xs text-body leading-relaxed bg-canvas-soft/30">
            If a domain receives a score below 50, do not enter any personal details, passcodes, or banking credentials. Close the page. If the score is for a job recruiter or SMS message, block the contact immediately and check the official corporate company directory to confirm if they actually reached out to you.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { triggerScamScan } from '../utils/scanEngine';

  function init() {
    // 1. Hero Search Input trigger
    const heroBtn = document.getElementById('hero-search-btn');
    const heroInput = document.getElementById('hero-search-input') as HTMLInputElement;

    if (heroBtn && heroInput) {
      heroBtn.addEventListener('click', () => {
        const value = heroInput.value.trim();
        if (!value) return;

        // Smart detect type based on input pattern
        let detectedType = 'website';
        const normalized = value.toLowerCase();

        // Phone number patterns
        if (/^[+]?[0-9()\s-]{7,20}$/.test(value) && value.replace(/[^0-9]/g, '').length >= 7) {
          detectedType = 'phone';
        }
        // SMS typical words
        else if (normalized.includes('delivery') || normalized.includes('alert') || normalized.includes('locked') || normalized.includes('sms') || normalized.includes('msg') || normalized.includes('winner') || normalized.includes('usps') || normalized.includes('usps-')) {
          if (value.includes(' ') && value.split(' ').length > 2) {
            detectedType = 'sms';
          }
        }
        // Job typical words
        else if (normalized.includes('telegram') || normalized.includes('whatsapp') || normalized.includes('hiring') || normalized.includes('pay rate') || normalized.includes('work from home')) {
          detectedType = 'job';
        }
        // Email typical patterns
        else if (normalized.includes('dear customer') || normalized.includes('subject:') || normalized.includes('regards')) {
          detectedType = 'email';
        }
        
        // Find matching input in the dashboard
        let targetTabBtn = document.querySelector(`[data-tab="${detectedType === 'website' ? 'url' : detectedType}"]`) as HTMLButtonElement;
        if (targetTabBtn) targetTabBtn.click();

        let inputId = 'input-url';
        if (detectedType === 'job') inputId = 'textarea-job';
        else if (detectedType === 'email') inputId = 'textarea-email';
        else if (detectedType === 'sms') inputId = 'textarea-sms';
        else if (detectedType === 'phone') inputId = 'input-phone';

        const dashboardInput = document.getElementById(inputId) as HTMLInputElement | HTMLTextAreaElement;
        if (dashboardInput) {
          dashboardInput.value = value;
          // Trigger the scanner
          triggerScamScan(value, detectedType === 'website' ? 'website' : detectedType);
        }
      });
      
      // Allow enter key trigger
      heroInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          heroBtn.click();
        }
      });
    }

    // 2. FAQ accordions
    const faqBtns = document.querySelectorAll('.faq-btn');
    faqBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const panel = btn.nextElementSibling as HTMLDivElement;
        const arrow = btn.querySelector('.faq-arrow') as SVGElement;
        
        if (!panel) return;
        
        // Close all other panels
        document.querySelectorAll('.faq-panel').forEach(p => {
          if (p !== panel) {
            p.setAttribute('style', 'max-height: 0px;');
            const otherBtn = p.previousElementSibling;
            if (otherBtn) {
              const otherArrow = otherBtn.querySelector('.faq-arrow');
              if (otherArrow) otherArrow.classList.remove('rotate-180');
            }
          }
        });

        // Toggle current panel
        if (panel.style.maxHeight && panel.style.maxHeight !== '0px') {
          panel.style.maxHeight = '0px';
          if (arrow) arrow.classList.remove('rotate-180');
        } else {
          panel.style.maxHeight = panel.scrollHeight + 'px';
          if (arrow) arrow.classList.add('rotate-180');
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
