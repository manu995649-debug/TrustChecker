---
import Layout from '../layouts/Layout.astro';
import InteractiveChecker from '../components/InteractiveChecker.astro';
---

<Layout 
  title="Online Store Checker - eCommerce Safety Audit - TrustChecker"
  description="Verify online shopping portals and store URLs before buying. Scan for domain registration age, checkout SSL encryption, and contact transparency."
  activePath="/online-store-checker"
>
  <div class="max-w-4xl mx-auto flex flex-col gap-10">
    <!-- Header -->
    <header class="text-center flex flex-col items-center gap-4 select-none">
      <span class="caption-mono text-link font-semibold">ECOMMERCE AUDIT</span>
      <h1 class="display-lg text-ink font-semibold">Online store checker.</h1>
      <p class="text-sm text-body max-w-lg">
        Instantly analyze shopping domains, check registry age, verify SSL locks, and review trust signals to identify fake ecommerce portals.
      </p>
    </header>

    <!-- Checker Dashboard -->
    <InteractiveChecker defaultTab="store" />

    <!-- Educational section -->
    <section class="border-t border-hairline pt-10 select-none flex flex-col gap-6">
      <h2 class="display-sm text-ink">How to identify fake eCommerce storefronts.</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-xs text-body leading-relaxed">
        <div class="flex flex-col gap-2 p-4 bg-canvas border border-hairline rounded shadow-level1">
          <span class="font-semibold text-error">1. Extreme Discount Advertising</span>
          <p>
            Sites advertising premium designer brands, hot toys, or high-end electronics at 80% to 90% discount (often seen on Facebook/Instagram ads) are almost always fake storefronts that capture card details.
          </p>
        </div>

        <div class="flex flex-col gap-2 p-4 bg-canvas border border-hairline rounded shadow-level1">
          <span class="font-semibold text-error">2. eCommerce Specific Extensions</span>
          <p>
            Exercise care when buying from sites ending in cheap TLDs like `.shop`, `.store`, `.sale`, or `.online`. Scammers register hundreds of these daily to launch throwaway drop-shipping stores.
          </p>
        </div>

        <div class="flex flex-col gap-2 p-4 bg-canvas border border-hairline rounded shadow-level1">
          <span class="font-semibold text-error">3. Missing Support Information</span>
          <p>
            Scam storefronts typically feature generic contact forms, fake physical maps, or email addresses hosted on public domains (e.g. `support-fashion@gmail.com`) instead of matching their own company domain.
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>
