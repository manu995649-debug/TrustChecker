---
import Layout from '../layouts/Layout.astro';
import InteractiveChecker from '../components/InteractiveChecker.astro';
---

<Layout 
  title="Website Scam Checker - Search Domain Safety - TrustChecker"
  description="Instantly scan any web URL or link for phishing clones, fake storefronts, and domain registration age threats. Run a free domain verification."
  activePath="/website-scam-checker"
>
  <div class="max-w-4xl mx-auto flex flex-col gap-10">
    <!-- Header -->
    <header class="text-center flex flex-col items-center gap-4 select-none">
      <span class="caption-mono text-link font-semibold">SECURITY AUDIT</span>
      <h1 class="display-lg text-ink font-semibold">Website scam checker.</h1>
      <p class="text-sm text-body max-w-lg">
        Audit any URL for potential malware, lookalike domain spoofing, and malicious scripts before visiting or sharing.
      </p>
    </header>

    <!-- Checker Dashboard -->
    <InteractiveChecker defaultTab="url" />

    <!-- Educational content -->
    <section class="border-t border-hairline pt-10 select-none flex flex-col gap-6">
      <h2 class="display-sm text-ink">Understanding domain warning signs.</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-xs text-body leading-relaxed">
        <div class="flex flex-col gap-2 p-4 bg-canvas border border-hairline rounded shadow-level1">
          <span class="font-semibold text-error">1. Newly Created Domain</span>
          <p>
            Scammers continuously register and discard domains. If a website has been registered for less than 90 days, it is highly likely to be a scam campaign.
          </p>
        </div>

        <div class="flex flex-col gap-2 p-4 bg-canvas border border-hairline rounded shadow-level1">
          <span class="font-semibold text-error">2. High-Discount eCommerce Bait</span>
          <p>
            Be suspicious of online shops using suspicious extensions (like `.xyz` or `.shop`) selling premium electronics or designer clothes at 70%+ off.
          </p>
        </div>

        <div class="flex flex-col gap-2 p-4 bg-canvas border border-hairline rounded shadow-level1">
          <span class="font-semibold text-error">3. Hidden Registrar Data</span>
          <p>
            Legitimate business entities share public corporate DNS records. Malicious actors hide contact data behind anonymous proxy services.
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>
