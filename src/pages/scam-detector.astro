---
import Layout from '../layouts/Layout.astro';
import InteractiveChecker from '../components/InteractiveChecker.astro';
import HistoryLog from '../components/HistoryLog.astro';
import CommunityReport from '../components/CommunityReport.astro';
---

<Layout 
  title="Scam Detector Dashboard - Realtime Risk Analytics - TrustChecker"
  description="Free realtime AI scam detection portal. Check websites, emails, SMS links, phone number reputations, and fake job recruiters in one console."
  activePath="/scam-detector"
>
  <div class="max-w-7xl mx-auto flex flex-col gap-12">
    <!-- Header -->
    <header class="text-center flex flex-col items-center gap-4 select-none">
      <span class="caption-mono text-link font-semibold">SECURITY DASHBOARD</span>
      <h1 class="display-lg text-ink font-semibold">Real-time scam detector.</h1>
      <p class="text-sm text-body max-w-lg">
        Your unified cybersecurity terminal to check and cross-reference potential threats. Get immediate trust diagnostics, SSL verification, and scam language classifications.
      </p>
    </header>

    <!-- Checker Dashboard -->
    <div class="max-w-4xl mx-auto w-full">
      <InteractiveChecker defaultTab="url" />
    </div>

    <!-- Live Logs & History grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left side: History Logs -->
      <div class="w-full lg:col-span-4">
        <HistoryLog />
      </div>

      <!-- Right side: Live Community Reports -->
      <div class="w-full lg:col-span-8 flex flex-col gap-6">
        <div class="flex flex-col gap-1 select-none">
          <span class="caption-mono text-error font-semibold font-mono text-[10px]">COMMUNITY ALERTS</span>
          <h2 class="text-lg font-semibold tracking-tight text-ink">Recent Flags Reported by Users</h2>
          <p class="text-xs text-body">Anonymous submissions entered by visitors to help identify active internet fraud campaigns.</p>
        </div>
        <CommunityReport />
      </div>
    </div>
  </div>
</Layout>
